<?xml version="1.0" encoding="utf-8" ?>
<embarkmodules>
  
  <module Class="XRL.CharacterBuilds.Qud.QudGamemodeModule">
    <modes>
      <mode ID="UD_Bones_Bones" Title="Bones">
        <icon Tile="Items/sw_bones_1.bmp" Foreground="y" Detail="K"></icon>
        <description>
          Land somewhere interesting, then immediately die.
        </description>
        <stringgamestate Name="GameMode" Value="UD_Bones_Bones"></stringgamestate>
      </mode>
    </modes>
  </module>
  
  <module Class="UD_Bones_Folder.Mod.UI.BonesModeModule">
    <window ID="Chargen/UD_Bones_BonesModeModule" Prefab="HorizScroll" Class="UD_Bones_Folder.Mod.UI.BonesModeModuleWindow">
      <name>Bones Mode</name>
      <title>:bones mode:</title>
    </window>
    
    <types>
      <type ID="InstantDeath" Title="Instant Death">
        <icon Tile="Creatures/sw_crowsong.bmp" Foreground="g" Detail="G"></icon>
        <description>
          Die immediately after landing somewhere interesting.
        </description>
      </type>
      
      <type ID="PokeAround" Title="Investigate First">
        <icon Tile="Mutations/night_vision_mutation.bmp" Foreground="b" Detail="B"></icon>
        <description>
          Have a poke around where you land
          Use the provided ability to instantly die.
        </description>
      </type>
    </types>
    
  </module>
  
</embarkmodules>
